<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Tema6 Groups Suite">

    <!-- Ruleaza doar testele din grupul smoke -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="Tema6"/>
        </classes>
    </test>

    <!-- Ruleaza doar testele din grupul regression -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="Tema6"/>
        </classes>
    </test>

</suite>